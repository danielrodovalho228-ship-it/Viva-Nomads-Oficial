# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...mas os exemplos (sem segredos) são versionados para documentar as variáveis.
!.env.example
!.env.capturas.example
!.env.testes.example

# Playwright (suíte E2E — npm run testes)
/playwright-report/
/tests/e2e/.auth/
/tests/e2e/.artifacts/
/test-results/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
screenshots/
