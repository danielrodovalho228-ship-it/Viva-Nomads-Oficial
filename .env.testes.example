# Suíte E2E (npm run testes) — copie para .env.local e preencha, OU configure
# como GitHub Secrets no CI. NUNCA comite valores reais. Use contas de TESTE
# (nunca a conta pessoal do Daniel).

# Alvo dos testes: preview da Vercel (recomendado) ou produção (só leitura).
TESTES_BASE_URL=https://SEU-PREVIEW.vercel.app

# Conta de teste — INQUILINO
TESTES_INQUILINO_EMAIL=
TESTES_INQUILINO_SENHA=
TESTES_INQUILINO_NOME=          # nome real esperado na saudação/sidebar (T4)

# Conta de teste — PROPRIETÁRIO
TESTES_PROPRIETARIO_EMAIL=
TESTES_PROPRIETARIO_SENHA=
TESTES_PROPRIETARIO_NOME=

# Conta de teste — ADMIN (para T4 demo ligado e T6)
TESTES_ADMIN_EMAIL=
TESTES_ADMIN_SENHA=
TESTES_ADMIN_NOME=

# Segurança do banco: o T5 CRIA um pedido. Contra produção, a criação é pulada
# por padrão. Só libere se souber o que está fazendo (ideal: rode no preview).
# TESTES_ALLOW_PROD_WRITES=1

# Chromium local (ambiente do agente): aponte para o binário pré-instalado.
# No CI o Playwright instala o próprio (npx playwright install chromium).
# PLAYWRIGHT_CHROMIUM_PATH=/opt/pw-browsers/chromium-1194/chrome-linux/chrome
