# Viva Nomads — variáveis de ambiente.
# Copie para .env.local. Sem nenhuma destas, a app roda em MODO DEMONSTRAÇÃO:
# cada integração ativa sozinha quando a chave correspondente é preenchida.

# ── Site ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://vivanomads.com.br

# ── Supabase (Postgres + Auth + Storage) ────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Chave de serviço — usada em rotas server-side sem usuário (ex.: webhooks).
# NUNCA exponha no cliente nem versione com valor real.
SUPABASE_SERVICE_ROLE_KEY=

# ── Asaas (pagamento nativo BR: assinatura + PIX/boleto/cartão + split) ──────
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=
ASAAS_ENV=sandbox            # sandbox | production

# ── Mapbox (mapas de imóveis e espaços de trabalho) ─────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=

# ── Google Places (espaços de trabalho próximos → selo Pronto para Trabalho) ─
GOOGLE_PLACES_API_KEY=

# ── CAF (verificação de inquilino) ──────────────────────────────────────────
CAF_API_TOKEN=
CAF_TEMPLATE_ID=
CAF_API_BASE=

# ── ZapSign (assinatura de contrato) ────────────────────────────────────────
ZAPSIGN_API_TOKEN=

# ── NFS-e (emissão de nota fiscal de serviço) ───────────────────────────────
NFSE_PROVIDER=
NFSE_API_TOKEN=

# ── Resend (e-mail transacional: novos leads, etc.) ─────────────────────────
RESEND_API_KEY=
RESEND_FROM=Viva Nomads <contato@vivanomads.com.br>

# ── Z-API (WhatsApp transacional) ───────────────────────────────────────────
ZAPI_INSTANCE=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=
