# ─────────────────────────────────────────────────────────────
# Viva Nomads — variáveis de ambiente
# Copie para .env.local e preencha. Sem elas, a app roda em modo demonstração.
# ─────────────────────────────────────────────────────────────

# Domínio público (usado em metadados, sitemap e robots)
NEXT_PUBLIC_SITE_URL=https://vivanomads.com.br

# Supabase (Postgres + Auth + Storage)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Pagamento nativo Brasil — Asaas (assinatura recorrente + PIX/boleto/cartão + split)
# ASAAS_ENV: "sandbox" (padrão) ou "production"
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=
ASAAS_ENV=sandbox

# Mapas (busca)
NEXT_PUBLIC_MAPBOX_TOKEN=

# Google Places (espaços de trabalho próximos — selo Pronto para Trabalho)
GOOGLE_PLACES_API_KEY=

# Integrações de fechamento (Fase 8 do documento mestre)
ZAPSIGN_API_TOKEN=
CAF_API_TOKEN=
CAF_TEMPLATE_ID=

# Garantidor digital (garantia locatícia via parceiro) — slot "Em breve" por padrão.
# Para LIGAR sem mexer no fluxo: defina "true" E cadastre o parceiro no catálogo
# de garantias com status 'ativo' (parceiro_nome preenchido). Só então o
# garantidor digital fica selecionável na etapa de garantia do fechamento.
NEXT_PUBLIC_GARANTIDOR_DIGITAL_ATIVO=false
# Nome do parceiro garantidor digital (exibido como "via {parceiro}" na UI).
# Deixe vazio para ocultar. Em produção, vem do Supabase (migração 0014).
NEXT_PUBLIC_GARANTIDOR_PARCEIRO_NOME=

# Mensageria — e-mail transacional (Resend)
RESEND_API_KEY=
RESEND_FROM="Viva Nomads <nao-responder@vivanomads.com.br>"

# Mensageria — WhatsApp (Z-API; alternativas: Twilio, Meta WhatsApp Business)
ZAPI_INSTANCE=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# NFS-e Nacional (receitas da plataforma) — Focus NFe ou PlugNotas
NFSE_API_TOKEN=
NFSE_PROVIDER=focus

# Analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
