# Capturas da demo (npm run capturas) — copie para .env.local e preencha.
# NUNCA use sua conta pessoal. Crie uma conta de TESTE (de preferência admin,
# para o modo demonstração aparecer). NÃO comite valores reais.

CAPTURAS_BASE_URL=https://SEU-PREVIEW.vercel.app   # ou a produção
CAPTURAS_EMAIL=conta-de-teste@exemplo.com
CAPTURAS_SENHA=coloque-uma-senha-de-teste

# Alternativa sem login real (injeta uma sessão admin + modo demo localmente):
#   CAPTURAS_DEMO=1 npm run capturas
